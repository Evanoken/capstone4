```gitignore
# Dependencies
node_modules/

# Environment variables
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist/
build/
coverage/
.next/
out/

# Cache
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo

# OS files
.DS_Store
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Runtime files
*.pid
*.seed
*.pid.lock

# Optional package manager files
.pnp/
.pnp.js

# Misc
.tmp/
temp/
```